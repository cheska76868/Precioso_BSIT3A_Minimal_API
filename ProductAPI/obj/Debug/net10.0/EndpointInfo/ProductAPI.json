            "type": "integer",
            "format": "int32"
          },
          "name": {
            "maxLength": 150,
            "minLength": 1,
            "type": "string"
          },
          "contactEmail": {
            "maxLength": 200,
            "type": "string",
            "nullable": true
          },
          "phone": {
            "maxLength": 20,
            "type": "string",
            "nullable": true
          },
          "address": {
            "maxLength": 300,
            "type": "string",
            "nullable": true
          },
          "products": {
            "type": "array",
            "items": {
